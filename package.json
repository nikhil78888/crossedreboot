{
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo run build --filter api",
    "start:api": "cd apps/api && yarn start",
    "clean": "turbo clean",
    "dev": "turbo dev --no-cache  --continue --concurrency 11",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "devDependencies": {
    "prettier": "^2.7.1",
    "turbo": "^1.9.3"
  },
  "packageManager": "yarn@1.22.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
