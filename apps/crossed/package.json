{
  "name": "crossed",
  "version": "1.0.0",
  "scripts": {
    "upload-puzzles": "ts-node ./upload-data/upload-puzzles",
    "clean": "rm -rf ios android .turbo node_modules .expo dist",
    "lint": "eslint \"src/**/*.ts*\"",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "build-simulator": "eas build --profile simulator --platform ios",
    "release-preview": "eas build --profile preview --platform ios",
    "release-to-store": "eas build --profile production --platform ios --auto-submit",
    "ota-to-store": "eas update --branch production --message auto",
    "ota-to-preview": "eas update --branch preview --message auto"
  },
  "dependencies": {
    "@expo-google-fonts/besley": "^0.2.3",
    "@expo-google-fonts/bitter": "^0.2.3",
    "@expo-google-fonts/lato": "^0.2.3",
    "@expo-google-fonts/prompt": "^0.2.3",
    "@expo/vector-icons": "^13.0.0",
    "@hookform/resolvers": "^3.1.0",
    "@logrocket/react-native": "^1.15.0",
    "@react-native-async-storage/async-storage": "1.18.2",
    "@react-native-firebase/analytics": "^18.3.0",
    "@react-native-firebase/app": "^17.4.2",
    "@react-native-firebase/auth": "^17.4.2",
    "@sentry/react-native": "5.5.0",
    "@supabase/supabase-js": "^2.24.0",
    "axios": "^1.4.0",
    "class-variance-authority": "^0.6.0",
    "date-fns": "^2.29.3",
    "expo": "~49.0.5",
    "expo-application": "~5.3.0",
    "expo-build-properties": "~0.8.3",
    "expo-constants": "~14.4.2",
    "expo-dev-client": "~2.4.6",
    "expo-device": "~5.4.0",
    "expo-font": "~11.4.0",
    "expo-image": "~1.3.2",
    "expo-linking": "~5.0.2",
    "expo-router": "2.0.0",
    "expo-secure-store": "~12.3.1",
    "expo-splash-screen": "~0.20.4",
    "expo-status-bar": "~1.6.0",
    "expo-updates": "~0.18.11",
    "firebase-admin": "^11.6.0",
    "immer": "^9.0.21",
    "nativewind": "^2.0.11",
    "react": "18.2.0",
    "react-hook-form": "^7.43.9",
    "react-native": "0.72.3",
    "react-native-avoid-softinput": "^4.0.0",
    "react-native-gesture-handler": "~2.12.0",
