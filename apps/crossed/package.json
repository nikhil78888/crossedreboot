{
  "name": "crossed",
  "version": "1.0.0",
  "scripts": {
    "upload-puzzles": "ts-node ./upload-data/upload-puzzles",
    "clean": "rm -rf ios android .turbo node_modules .expo dist",
    "start": "dotenv -e .env -- expo start --dev-client",
    "android": "dotenv -e .env -- expo run:android",
    "ios": "dotenv -e .env -- expo run:ios",
    "web": "dotenv -e .env -- expo start --web",
    "prebuild": "dotenv -e .env -- expo prebuild --clean",
    "build-simulator": "eas build --profile simulator --platform ios",
    "release-preview": "eas build --profile preview --platform ios",
    "release-to-store": "eas build --profile production --platform ios --auto-submit",
    "ota-to-store": "eas update --branch production --message auto",
    "ota-to-preview": "eas update --branch preview --message auto"
  },
  "dependencies": {
    "@expo-google-fonts/bitter": "^0.2.3",
    "@expo-google-fonts/lato": "^0.2.3",
    "@expo/vector-icons": "^13.0.0",
    "@hookform/resolvers": "^3.1.0",
    "@logrocket/react-native": "^1.15.0",
    "@react-native-async-storage/async-storage": "1.17.11",
    "@react-native-firebase/app": "^17.4.2",
    "@react-native-firebase/auth": "^17.4.2",
    "@react-native-firebase/firestore": "^17.4.2",
    "@sentry/react-native": "4.13.0",
    "@supabase/supabase-js": "^2.24.0",
    "axios": "^1.4.0",
    "class-variance-authority": "^0.6.0",
    "date-fns": "^2.29.3",
    "expo": "~48.0.18",
    "expo-application": "~5.1.1",
    "expo-build-properties": "~0.6.0",
    "expo-constants": "~14.2.1",
    "expo-dev-client": "~2.2.1",
    "expo-device": "~5.2.1",
    "expo-font": "~11.1.1",
    "expo-image": "~1.0.0",
    "expo-linking": "~4.0.1",
    "expo-router": "^1.5.3",
    "expo-secure-store": "~12.1.1",
    "expo-splash-screen": "~0.18.2",
    "expo-status-bar": "~1.4.4",
    "expo-updates": "~0.16.4",
    "firebase-admin": "^11.6.0",
    "immer": "^9.0.21",
    "nativewind": "^2.0.11",
    "react": "18.2.0",
    "react-hook-form": "^7.43.9",
    "react-native": "0.71.8",
    "react-native-gesture-handler": "~2.9.0",
    "react-native-keyboard-controller": "^1.5.8",
    "react-native-reanimated": "~2.14.4",
    "react-native-safe-area-context": "4.5.0",
    "react-native-screens": "~3.20.0",
    "react-native-ui-lib": "^7.3.2",
    "react-native-url-polyfill": "^1.3.0",
    "react-native-webview": "11.26.0",
    "sentry-expo": "~6.1.0",
    "swr": "^2.1.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/node": "^18.16.1",
    "@types/react": "~18.0.14",
    "@typescript-eslint/eslint-plugin": "5.57.1",
    "@typescript-eslint/parser": "5.57.1",
    "dotenv-cli": "^7.2.1",
    "eslint": "8.37.0",
    "eslint-config-next": "13.2.4",
    "eslint-config-prettier": "8.8.0",
    "prettier": "2.8.7",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4"
  },
  "resolutions": {
    "metro": "0.76.0",
    "metro-resolver": "0.76.0"
  },
  "private": true
}
