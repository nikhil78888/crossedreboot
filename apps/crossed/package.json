{
  "name": "crossed",
  "version": "1.0.0",
  "scripts": {
    "upload-puzzles": "ts-node ./upload-data/upload-puzzles",
    "clean": "rm -rf ios android .turbo node_modules .expo dist",
    "lint": "eslint \"src/**/*.ts*\"",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "build-simulator": "eas build --profile simulator --platform ios",
    "release-development": "eas build --profile development --platform ios",
    "release-preview": "eas build --profile preview --platform ios",
    "release-to-store": "eas build --profile production --platform ios --auto-submit",
    "ota-to-store": "eas update --branch production --message auto",
    "ota-to-preview": "eas update --branch preview --message auto"
  },
  "dependencies": {
    "@expo-google-fonts/besley": "^0.2.3",
    "@expo-google-fonts/bitter": "^0.2.3",
    "@expo-google-fonts/jost": "^0.2.3",
    "@expo-google-fonts/lato": "^0.2.3",
    "@expo-google-fonts/montserrat": "^0.2.3",
    "@expo-google-fonts/mukta": "^0.2.3",
    "@expo-google-fonts/prompt": "^0.2.3",
    "@expo-google-fonts/rubik": "^0.2.3",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^3.1.0",
    "@logrocket/react-native": "^1.19.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.24.0",
    "axios": "^1.4.0",
    "class-variance-authority": "^0.6.0",
    "date-fns": "^2.29.3",
    "expo": "~55.0.0",
    "expo-application": "~55.0.0",
    "expo-build-properties": "~55.0.0",
    "expo-constants": "~55.0.0",
    "expo-dev-client": "~55.0.0",
    "expo-device": "~55.0.0",
    "expo-font": "~55.0.0",
    "expo-image": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-secure-store": "~55.0.0",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "expo-updates": "~55.0.0",
    "immer": "^9.0.21",
    "mixpanel-react-native": "^2.3.1",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-hook-form": "^7.43.9",
    "react-native": "0.83.6",
    "react-native-avoid-softinput": "^8.0.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-purchases": "^10.1.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-ui-lib": "^7.3.2",
    "react-native-url-polyfill": "^1.3.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "swr": "^2.1.2",
    "zod": "^3.21.4"
