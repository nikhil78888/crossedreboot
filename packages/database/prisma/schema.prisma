generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model profiles {
  userId      String        @unique
  country     String?
  username    String        @unique
  email       String?       @unique
  name        String?
  avatar      String?
  eloRating   Float         @default(1000)
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime      @default(now())
  gamePlayers gamePlayers[]
  games       games[]

  @@index([userId])
}

model crosswords {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  size        Int
  difficulty  Int
  isPublished Boolean
  source      CrosswordSource
  category    CrosswordCategory
  puzzle      String[]
  solution    String[]
  clues       Json
  games       games[]
  createdAt   DateTime          @default(now())
}

enum CrosswordSource {
  wizium
  aicross
}

enum CrosswordCategory {
  general
  sports
  history
  geography
  science
  politics
  movies
  television
  pop_culture
}

model games {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crossword             crosswords    @relation(fields: [crosswordsId], references: [id])
  crosswordsId          String        @db.Uuid
  gameType              GameType
  gameDurationInSeconds Int
  playState             PlayState
  gameState             Json?
  gamePlayers           gamePlayers[]
  winner                profiles?     @relation(fields: [winnerId], references: [id])
  winnerId              String?       @db.Uuid
  startedAt             DateTime?
  createdAt             DateTime      @default(now())
}

model gamePlayers {
  game       games    @relation(fields: [gamesId], references: [id], onDelete: Cascade)
  player     profiles @relation(fields: [profilesId], references: [id], onDelete: Cascade)
  gamesId    String   @db.Uuid
  profilesId String   @db.Uuid
  score      Int      @default(0)

  @@id([gamesId, profilesId])
}

enum PlayState {
  WAITING_FOR_OPPONENT
  PLAYING
  COMPLETED
  ABORTED
}

enum GameType {
  SOLO
  FRIENDLY
  RANKED
}

model words {
  id         Int       @id @default(autoincrement())
  word       String
  wordLength Int       @default(0)
  lastUsed   DateTime?
  clue       String?
  score      Int?

  @@unique([word, clue])
}
