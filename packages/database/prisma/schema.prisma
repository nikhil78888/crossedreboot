generator client {
  provider = "prisma-client-js"
  // previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // schemas  = ["auth", "public"]
}

model profiles {
  userId    String  @id
  username  String
  firstName String?
  lastName  String?
  country   String?
}
