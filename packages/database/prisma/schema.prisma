generator client {
  provider = "prisma-client-js"
  // previewFeatures = ["multiSchema"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  // schemas  = ["auth", "public"]
}

model profiles {
  userId   String  @id
  username String  @unique
  avatar   String?
  email    String? @unique
  name     String?
  country  String?
}
