generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model profiles {
  userId      String        @unique
  country     String?
  username    String        @unique
  email       String?       @unique
  name        String?
  avatar      String?
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime      @default(now())
  gamePlayers gamePlayers[]

  @@index([userId])
}

model crosswords {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  size        Int
  difficulty  Int
  isPublished Boolean
  source      CrosswordSource
  category    CrosswordCategory
  puzzle      String[]
  solution    String[]
  clues       Json
  games       games[]
}

enum CrosswordSource {
  wizium
}

enum CrosswordCategory {
  general
  sports
  history
  geography
  science
  politics
  movies
  television
  pop_culture
}

model games {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crossword             crosswords    @relation(fields: [crosswordsId], references: [id])
  crosswordsId          String        @db.Uuid
  gameType              GameType
  gameDurationInSeconds Int
  playState             PlayState
  gameState             Json?
  gamePlayers           gamePlayers[]
  startedAt             DateTime?
  createdAt             DateTime      @default(now())
}

model gamePlayers {
  game       games    @relation(fields: [gamesId], references: [id], onDelete: Cascade)
  player     profiles @relation(fields: [profilesId], references: [id], onDelete: Cascade)
  gamesId    String   @db.Uuid
  profilesId String   @db.Uuid

  @@id([gamesId, profilesId])
}

enum PlayState {
  WAITING_FOR_OPPONENT
  PLAYING
  COMPLETED
  ABORTED
}

enum GameType {
  SOLO
  FRIENDLY
  RANKED
}
