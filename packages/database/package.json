{
  "name": "database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsc -w",
    "lint": "eslint \"src/**/*.ts*\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:pull": "prisma db pull"
  },
  "dependencies": {
    "@prisma/client": "4.15.0"
  },
  "devDependencies": {
    "@types/jest": "^26.0.22",
    "@types/node": "^18.11.9",
    "eslint": "^7.32.0",
    "eslint-config-custom": "*",
    "jest": "^26.6.3",
    "jest-presets": "*",
    "prisma": "4.15.0",
    "tsconfig": "*",
    "typescript": "^4.8.3"
  }
}
